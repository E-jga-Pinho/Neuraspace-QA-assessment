  "item": [
    {
      "name": "Get data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"EPOCH is within the last 30 days\", function () {",
              "    var jsonData = pm.response.json();",
              "    var now = new Date();",
              "    var thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);",
              "",
              "    jsonData.forEach(function (item) {",
              "        var epochDate = new Date(item.EPOCH);",
              "        pm.expect(epochDate.getTime(), \"EPOCH \" + item.EPOCH + \" for \" + item.OBJECT_NAME + \" should be within the last 30 days\").to.be.at.least(thirtyDaysAgo.getTime());",
              "        pm.expect(epochDate.getTime(), \"EPOCH \" + item.EPOCH + \" for \" + item.OBJECT_NAME + \" should not be in the future\").to.be.at.most(now.getTime());",
              "    });",
              "});",
              "",
              "pm.test(\"OBJECT_ID follows YYYY-NNNP{PP} format\", function () {",
              "    var jsonData = pm.response.json();",
              "    var objectIdPattern = /^\\d{4}-\\d{3}[A-Z]+$/;",
              "",
              "    jsonData.forEach(function (item) {",
              "        pm.expect(",
              "            objectIdPattern.test(item.OBJECT_ID),",
              "            \"OBJECT_ID '\" + item.OBJECT_ID + \"' for \" + item.OBJECT_NAME + \" does not match expected format YYYY-NNNP{PP}\"",
              "        ).to.be.true;",
              "    });",
              "});",
              "",
              "pm.test(\"OBJECT_ID year matches EPOCH year\", function () {",
              "    var jsonData = pm.response.json();",
              "",
              "    jsonData.forEach(function (item) {",
              "        var objectIdYear = parseInt(item.OBJECT_ID.split(\"-\")[0], 10);",
              "        var epochYear = new Date(item.EPOCH).getFullYear();",
              "        pm.expect(",
              "            objectIdYear,",
              "            \"OBJECT_ID year '\" + objectIdYear + \"' for \" + item.OBJECT_NAME + \" does not match EPOCH year '\" + epochYear + \"'\"",
              "        ).to.equal(epochYear);",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
